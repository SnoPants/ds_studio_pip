        -command "import maya.cmds as cmds\n\ndef select_children_meshes():\n    \"\"\"Expands the selection to include all child mesh transform nodes of the selected objects.\"\"\"\n\n    selected = cmds.ls(selection=True)\n\n    if not selected:\n        cmds.warning(\"Please select at least one object.\")\n        return\n\n    all_mesh_transforms = []\n\n    for obj in selected:\n        # Find all descendant mesh shapes\n        mesh_shapes = cmds.listRelatives(obj, allDescendents=True, type=\"mesh\", fullPath=True) or []\n\n        for mesh in mesh_shapes:\n            # Get the parent transform of the mesh shape\n            mesh_transform = cmds.listRelatives(mesh, parent=True, fullPath=True)[0]\n            all_mesh_transforms.append(mesh_transform)\n\n    # Add original selection and remove duplicates\n    all_mesh_transforms.extend(selected)\n    unique_selection = list(set(all_mesh_transforms))\n\n    # Select the final list\n    cmds.select(unique_selection, replace=True)\n\n# Run it\nselect_children_meshes()\n" 
