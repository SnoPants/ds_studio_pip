        -image "normalDetails.svg" 
        -image1 "normalDetails.svg" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.api.OpenMaya as om\nimport maya.cmds as cmds\n\ndef get_vertex_normal_count(mesh_name=None):\n    # Use selected mesh if none provided\n    if not mesh_name:\n        sel = cmds.ls(selection=True, dag=True, type='mesh')\n        if not sel:\n            cmds.error(\"Please select a mesh.\")\n        mesh_name = sel[0]\n\n    # Get the MObject of the mesh\n    sel_list = om.MSelectionList()\n    sel_list.add(mesh_name)\n    dag_path = sel_list.getDagPath(0)\n\n    mesh_fn = om.MFnMesh(dag_path)\n\n    # Get normal count — this will return the number of **per-vertex-per-face** normals\n    normals = mesh_fn.getNormals()\n    normal_count = len(normals)\n\n    print(f\"{mesh_name} has {normal_count} vertex normals.\")\n    return normal_count\n\n# Example use:\nget_vertex_normal_count()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
