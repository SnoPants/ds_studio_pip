        -command "import maya.cmds as cmds\n\ndef disable_local_rotation_axes():\n    \"\"\"\n    Iterates through all transform nodes in the scene and turns off their\n    local rotation axis display.\n    \"\"\"\n    # List all transform nodes in the scene.\n    transforms = cmds.ls(type=\"transform\")\n    \n    for transform in transforms:\n        # Check if the transform node has the 'displayLocalAxis' attribute.\n        if cmds.attributeQuery(\"displayLocalAxis\", node=transform, exists=True):\n            try:\n                # Turn off the local rotation axis display (0 means off).\n                cmds.setAttr(f\"{transform}.displayLocalAxis\", 0)\n            except Exception as e:\n                cmds.warning(f\"Failed to set attribute on {transform}: {e}\")\n    \n    print(\"Local rotation axes have been disabled for all transform nodes.\")\n\n# Run the function.\ndisable_local_rotation_axes()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
