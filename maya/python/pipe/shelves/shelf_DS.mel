        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from PySide2 import QtWidgets, QtCore, QtUiTools, QtGui\nfrom PySide2.QtWidgets import QApplication\nimport importlib\nimport sys\nimport maya.cmds as mc\nimport os\nimport re\nimport stat\nimport json\n\n\n\"\"\"A Window class that allows for loading a Qt .ui file into Maya.\"\"\"\nglobal slash\nslash = os.sep\nglobal ui_file\nui_file = os.path.join(os.environ['USERPROFILE'], 'Documents', f'maya{slash}scripts{slash}Wearable_SK_Exporter{slash}UI{slash}SK_exporter_interface.ui')\nmap_ui_file = os.path.join(os.environ['USERPROFILE'], 'Documents', f'maya{slash}scripts{slash}Wearable_SK_Exporter{slash}UI{slash}Dynamic_Mapping.ui')\ndir_path = os.path.join(os.environ['USERPROFILE'], 'Documents', f'maya{slash}scripts{slash}Wearable_SK_Exporter')\n\nif not dir_path in sys.path:\n    sys.path.insert(0,dir_path)\n    \ntry:\n    from scripts import wearable_exporter\n    importlib.reload(wearable_exporter)\n    from scripts import Dynamic_Mapping\n    importlib.reload(Dynamic_Mapping)\nexcept Exception as e:\n    print(f\"Error reloading modules: {e}\")\n\ndef getMayaWindow():\n    \"\"\"Get the Maya main window as a QMainWindow instance.\"\"\"\n    app = QtWidgets.QApplication.instance()\n    if not app:\n        app = QtWidgets.QApplication(sys.argv)\n\n    mayaWindow = next(w for w in app.topLevelWidgets() if w.objectName() == \"MayaWindow\")\n    return mayaWindow\n\nclass Window(QtWidgets.QWidget):\n    \"\"\"A window that can be loaded from a Qt .ui file.\"\"\"\n\n    def __init__(self, filePath):\n        \"\"\"Initialize the window.\"\"\"\n        super().__init__()\n        self.filePath = filePath\n        self.MainWindow = None\n        self.ui = None\n        self.loadUIFile()\n        self.setAttribute(QtCore.Qt.WA_DeleteOnClose)\n\n    def loadUIFile(self, parent=None):\n        \"\"\"Load the UI file and return the widget.\"\"\"\n        if parent is None:\n            parent = getMayaWindow()\n        loader = QtUiTools.QUiLoader()\n        uiFile = QtCore.QFile(self.filePath)\n        uiFile.open(QtCore.QFile.ReadOnly)\n        ui = loader.load(uiFile, parent)\n        uiFile.close()\n                \n        ui.A_Dynamic_Mapping.triggered.connect(self.DynamicMapping_Click)\n        ui.QDynamicMap_CheckBox.stateChanged.connect(self.Check_Box_DynamicMapping)\n        ui.QStaticMesh_CheckBox.stateChanged.connect(self.Check_Box_StaticMesh)\n        ui.QDirectoryButton.clicked.connect(self.SetDirectory_Click)\n        ui.QSetJointButton.clicked.connect(self.SetJoint_Click)\n        ui.QSetMeshesButton.clicked.connect(self.SetMeshes_Click)\n        ui.QExportButton.clicked.connect(self.ExportMeshes_Click)\n        ui.QExportProgressBar.setVisible(False)\n        ui.QExitButton.clicked.connect(self.close)\n        \n        self.ui = ui\n        \n        return ui\n    \n    def Check_Box_StaticMesh(self):\n        if self.ui.QStaticMesh_CheckBox.isChecked():\n            self.ui.QRootJoint.setEnabled(False)\n            self.ui.QSetJointButton.setEnabled(False)\n            self.ui.SetJointLabel.setEnabled(False)\n        else:\n            self.ui.QRootJoint.setEnabled(True)\n            self.ui.QSetJointButton.setEnabled(True)\n            self.ui.SetJointLabel.setEnabled(True)\n    \n    def DynamicMapping_Click(self):\n        dwin = Dynamic_Mapping.main(map_ui_file, dir_path)\n        return\n    \n    def Check_Box_DynamicMapping(self):\n        if self.ui.QDynamicMap_CheckBox.isChecked():\n            self.ui.QDirectoryButton.setEnabled(False)\n            self.ui.QDirectoryLocation.setEnabled(False)\n            self.ui.DirectoryLabel.setEnabled(False)\n        else:\n            self.ui.QDirectoryButton.setEnabled(True)\n            self.ui.QDirectoryLocation.setEnabled(True)\n            self.ui.DirectoryLabel.setEnabled(True)\n\n    \n    def SetDirectory_Click(self):\n        \"\"\"Open a file dialog to select a directory.\"\"\"\n        directory = QtWidgets.QFileDialog.getExistingDirectory(self.MainWindow, \"Select Directory\")\n        if directory:\n            self.ui.QDirectoryLocation.clear()\n            self.ui.QDirectoryLocation.setText(directory)    \n        \n    def SetJoint_Click(self):\n        joint= mc.ls(sl=True)[0]\n        if mc.objectType(joint, isType='joint') == 1:\n            self.ui.QRootJoint.clear()\n            root = FindRootJnt(joint)\n            self.ui.QRootJoint.setText(root)\n        else:\n            mc.warning(f\"{joint} is not a 'joint' type.\")\n\n    def SetMeshes_Click(self):\n        self.ui.QMeshList.clear() \n        meshes = mc.ls(sl=True)\n        for i in meshes:\n            shapes = mc.listRelatives(i, shapes=True)\n            \n            if not shapes:\n                mc.warning(f\"{i} is not a mesh. It will not be added to the Export List.\")\n            else:\n                self.ui.QMeshList.addItem(i)\n\n    def GetMeshList(self):\n        \n        list = []\n        \n        numItems = self.ui.QMeshList.count()\n        \n        for i in range(numItems):\n            item = self.ui.QMeshList.item(i)\n            list.append(item.text())\n            \n        return list\n                \n    def ExportMeshes_Click(self):\n\n        use_mapping= self.ui.QDynamicMap_CheckBox.isChecked()\n        use_static= self.ui.QStaticMesh_CheckBox.isChecked()\n        \n        if use_static != True:\n            jnt = self.ui.QRootJoint.text()\n        else:\n            jnt = None\n            \n        meshes = self.GetMeshList()\n        \n        \n        if use_mapping == True:\n            directories = self.load_mapping()\n            for string, path in directories.items():\n                meshes_export = ReplaceCheck(meshes, path)\n        else:\n            directories = self.ui.QDirectoryLocation.text()\n            meshes_export = ReplaceCheck(meshes, directories)\n        \n        self.ui.QExportProgressBar.setMaximum(len(meshes_export))\n        self.ui.QExportProgressBar.setValue(0)\n        \n        try:\n            self.resetProgressBar()\n            self.showProgressBar()\n            wearable_exporter.Main(jnt, meshes_export, directories, use_mapping, use_static, self.update_progress)\n        except Exception as e:\n            mc.error(f\"Error exporting meshes: {e}\")\n        finally:\n            self.hideProgressBar()\n            \n    def load_mapping(self):\n        \n        mapping = {}\n        \n        json_file_path = os.path.join(dir_path,'DynamicMapping.json')\n        \n        if os.path.exists(json_file_path):\n                try:\n                    with open(json_file_path, 'r') as json_file:\n                        data_list = json.load(json_file)\n                    \n                    for data in data_list:\n                        sub_string =  data.get('sub_string', '')\n                        file_path =  data.get('file_path', '')\n                        mapping[sub_string] = file_path\n                        \n                        \n                except Exception as e:\n                    mc.error(f\"Error reading json file: {e}\")\n        \n        return mapping\n        \n    def show(self):\n        \"\"\"Show the window.\"\"\"\n        self.close()\n        self.MainWindow = self.loadUIFile()\n        self.MainWindow.show()\n\n    def close(self):\n        \"\"\"Close the window.\"\"\"\n        if self.MainWindow is not None:\n            sys.path = [path for path in sys.path if path != dir_path]\n            self.MainWindow.close()\n            self.MainWindow = None\n            \n    def showProgressBar(self):\n        \"\"\"Show the progress bar.\"\"\"\n        self.ui.QExportProgressBar.setVisible(True)\n        QApplication.processEvents()\n        \n    def hideProgressBar(self):\n        \"\"\"Hide the progress bar.\"\"\"\n        self.ui.QExportProgressBar.setVisible(False)\n        QApplication.processEvents()\n        \n    def resetProgressBar(self):\n        \"\"\"Reset the progress bar value to 0.\"\"\"\n        self.ui.QExportProgressBar.setValue(0)\n        QApplication.processEvents()\n        \n    def update_progress(self, value, max_value = None):\n        if max_value is not None:\n            self.ui.QExportProgressBar.setMaximum(max_value)\n        self.ui.QExportProgressBar.setValue(value)\n        QApplication.processEvents()  # Ensure the UI updates immediately\n\ndef showWindow():\n    \"\"\"This is the entry point of the script. Create an instance of the Window class and show it.\"\"\"\n    global win\n    win = Window(ui_file)\n    win.show()\n\ndef FindRootJnt(jnt):\n    parent = mc.listRelatives(jnt, p=True)\n    if parent:\n        parent = parent[0]\n        return FindRootJnt(parent)\n    else:\n        return jnt\n        \ndef ReplaceCheck(meshes, directory):\n    \n    files_in_directory = os.listdir(directory)\n    \n    matching_files_substring = [file for file in files_in_directory if any(mesh in file for mesh in meshes)]\n    \n    replace_files = []\n    readable_only = []\n    export_all = []\n    \n    for file in matching_files_substring:\n        if not Is_Readable(os.path.join(directory, file)):\n            replace_files.append(os.path.splitext(file)[0])\n            export_all.append(os.path.splitext(file)[0])\n        else:\n            readable_only.append(os.path.splitext(file)[0])\n    \n    writable_meshes = [mesh for mesh in meshes if mesh not in readable_only]\n\n    if readable_only:\n        readable_matches = \"\\n\".join(readable_only)\n        mc.confirmDialog(title='Readable Only', message=f'These Files are set to Readable-Only. Make sure these files are checked-out in PV4.\\n\\n{readable_matches}', button=['OK'])\n        \n    if replace_files:\n        replace_matches = \"\\n\".join(replace_files)\n        confirmation = mc.confirmDialog(title='Replace Files?', message=f'Would you like to replace these files?\\n\\n{replace_matches}', button=['OK', 'Cancel'], defaultButton= 'OK', cancelButton = 'Cancel', dismissString='Cancel')\n        \n        if confirmation == 'OK':\n            return writable_meshes\n            \n        elif confirmation == 'Cancel':\n            non_replace_meshes = [mesh for mesh in writable_meshes if mesh not in replace_files]\n            return non_replace_meshes\n            \n    return meshes\n    \ndef Is_Readable(filepath):\n    file_stat = os.stat(filepath)\n    # Check if the file is read-only by comparing the mode\n    # A file is read-only if it is not writable by the owner, group, or others\n    return not (file_stat.st_mode & stat.S_IWUSR or file_stat.st_mode & stat.S_IWGRP or file_stat.st_mode & stat.S_IWOTH)   \n    \nshowWindow()\n\n\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
