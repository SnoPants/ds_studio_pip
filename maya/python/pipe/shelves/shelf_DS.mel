        -command "import maya.cmds as cmd\nimport maya.mel as mel\n\ndef weldTheBitches():\n    verts = cmd.ls(fl = True, os = True)\n    cmd.select(verts[0])\n    mel.eval('artAttrSkinWeightCopy')\n    cmd.select(verts)\n    this = mel.eval('artAttrSkinWeightPaste')\n\tprint(this)\nweldTheBitches()" 
