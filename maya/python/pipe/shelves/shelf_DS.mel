        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import pymel.core as pm\n\ndef replace_and_rename():\n    sel = pm.ls(selection=True)\n    \n    if len(sel) != 2:\n        pm.warning(\"Please select exactly 2 objects.\")\n        return\n\n    original_name = sel[0].name()\n    to_rename = sel[1]\n\n    # Delete the first selected object\n    try:\n        pm.delete(sel[0])\n    except RuntimeError as e:\n        pm.warning(f\"Could not delete first object: {e}\")\n        return\n\n    # Make sure the name isn't taken after delete\n    if pm.objExists(original_name):\n        pm.warning(f\"Name '{original_name}' is still taken. Renaming skipped.\")\n        return\n\n    # Rename second object to the original name\n    try:\n        pm.rename(to_rename, original_name)\n    except RuntimeError as e:\n        pm.warning(f\"Could not rename second object: {e}\")\n\n    print(f\"Deleted first object and renamed second to '{original_name}'.\")\n\n# Run it:\nreplace_and_rename()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
