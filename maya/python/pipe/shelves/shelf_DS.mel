        -annotation "Select the source root object of heir that has keys, then select the target object root object of heir, then run. This goes off of name case. So if names match it will copy keys over." 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Copy_Anim" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Copy_Anim" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "copySkinWeight.png" 
        -image1 "copySkinWeight.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nimport re\n\n# ----------------------------\n# Helpers\n# ----------------------------\n\ndef has_parent(root):\n    parent = cmds.listRelatives(root, parent=True)\n    if parent:\n        raise ValueError(\"Please select root objects only (source, then target).\")\n\ndef get_transform_objects(root):\n    \"\"\"Return ALL non-locator transform descendants as FULL DAG paths.\"\"\"\n    all_transforms = cmds.listRelatives(root, ad=True, type='transform', fullPath=True) or []\n    clean_transforms = []\n    for t in all_transforms:\n        shapes = cmds.listRelatives(t, shapes=True, fullPath=True) or []\n        is_locator = any(cmds.objectType(s) == 'locator' for s in shapes)\n        if not is_locator:\n            clean_transforms.append(t)\n    return clean_transforms\n\ndef dag_depth(path):\n    \"\"\"Depth based on number of '|' in full path. Root has depth 0 or 1 depending on naming.\"\"\"\n    return path.count('|')\n\ndef get_final_token(name, strip_trailing_digits=True):\n    \"\"\"\n    Extract the final meaningful token of a node name:\n    - use full DAG path's last component\n    - strip namespace\n    - lower-case\n    - optionally drop trailing digits (e.g., 'head1' -> 'head')\n    \"\"\"\n    short = name.split('|')[-1]              # last path segment\n    short = short.split(':')[-1]             # strip namespace\n    if strip_trailing_digits:\n        short = re.sub(r'\\d+$', '', short)   # drop trailing digits\n    return short.lower()\n\ndef bucket_by_token(nodes, strip_trailing_digits=True):\n    \"\"\"Map token -> list of full DAG paths with that token.\"\"\"\n    buckets = {}\n    for n in nodes:\n        tok = get_final_token(n, strip_trailing_digits=strip_trailing_digits)\n        buckets.setdefault(tok, []).append(n)\n    return buckets\n\ndef pair_by_depth(source_list, target_list):\n    \"\"\"\n    Deterministically pair multiple source/target nodes sharing the same token.\n    Sort both lists by DAG depth (shallow->deep) and pair in order.\n    \"\"\"\n    s_sorted = sorted(source_list, key=dag_depth)\n    t_sorted = sorted(target_list, key=dag_depth)\n    return list(zip(s_sorted, t_sorted))\n\n# ----------------------------\n# Core: Key transfer\n# ----------------------------\n\ndef match_string_and_keyframes(source_nodes, target_nodes, strip_trailing_digits=True):\n    \"\"\"\n    Copy keyed TR/RO values from source -> target for nodes whose final tokens match.\n    Uses full DAG paths to avoid 'More than one object matches name' errors.\n    If multiple nodes share the same token on both sides:\n      - If counts match, pair deterministically by DAG depth.\n      - If counts differ, skip the token with a warning.\n    \"\"\"\n    print('Matching keys...')\n    s_b = bucket_by_token(source_nodes, strip_trailing_digits=strip_trailing_digits)\n    t_b = bucket_by_token(target_nodes, strip_trailing_digits=strip_trailing_digits)\n\n    common = sorted(set(s_b.keys()) & set(t_b.keys()))\n    if not common:\n        print(\"No matching pairs found.\")\n        return\n\n    print(\"Common tokens:\", common)\n\n    attrs = ['translateX', 'translateY', 'translateZ',\n             'rotateX', 'rotateY', 'rotateZ']\n\n    for tok in common:\n        s_list = s_b[tok]\n        t_list = t_b[tok]\n\n        if len(s_list) == 1 and len(t_list) == 1:\n            pairs = [(s_list[0], t_list[0])]\n        elif len(s_list) == len(t_list):\n            pairs = pair_by_depth(s_list, t_list)\n            print(f'Info: token \"{tok}\" has {len(s_list)} matches; pairing by DAG depth.')\n        else:\n            print(f'Warning: token \"{tok}\" has {len(s_list)} source vs {len(t_list)} target matches. Skipping to avoid ambiguity.')\n            continue\n\n        for src, trg in pairs:\n            print(f'Match: {src}  ->  {trg}  [token: {tok}]')\n\n            for attr in attrs:\n                key_count = cmds.keyframe(f'{src}.{attr}', query=True, keyframeCount=True)\n                if not key_count:\n                    continue\n\n                key_times = cmds.keyframe(f'{src}.{attr}', query=True) or []\n                for t in key_times:\n                    cmds.currentTime(t, edit=True)\n\n                    if 'translate' in attr:\n                        src_w_t = cmds.xform(src, q=True, ws=True, t=True)\n                        trg_w_t = cmds.xform(trg, q=True, ws=True, t=True)\n                        if 'translateX' in attr:\n                            cmds.xform(trg, ws=True, t=[src_w_t[0], trg_w_t[1], trg_w_t[2]])\n                        elif 'translateY' in attr:\n                            cmds.xform(trg, ws=True, t=[trg_w_t[0], src_w_t[1], trg_w_t[2]])\n                        elif 'translateZ' in attr:\n                            cmds.xform(trg, ws=True, t=[trg_w_t[0], trg_w_t[1], src_w_t[2]])\n                        cmds.setKeyframe(trg, at=attr)\n\n                    elif 'rotate' in attr:\n                        src_w_r = cmds.xform(src, q=True, ws=True, ro=True)\n                        trg_w_r = cmds.xform(trg, q=True, ws=True, ro=True)\n                        if 'rotateX' in attr:\n                            cmds.xform(trg, ws=True, ro=[src_w_r[0], trg_w_r[1], trg_w_r[2]])\n                        elif 'rotateY' in attr:\n                            cmds.xform(trg, ws=True, ro=[trg_w_r[0], src_w_r[1], trg_w_r[2]])\n                        elif 'rotateZ' in attr:\n                            cmds.xform(trg, ws=True, ro=[trg_w_r[0], trg_w_r[1], src_w_r[2]])\n                        cmds.setKeyframe(trg, at=attr)\n\n# ----------------------------\n# Entry point\n# ----------------------------\n\ndef run_transfer(strip_trailing_digits=True):\n    sel = cmds.ls(sl=True, long=True) or []\n    if len(sel) != 2:\n        raise ValueError(\"Please select exactly two root objects: source then target.\")\n\n    source_root, target_root = sel\n\n    has_parent(source_root)\n    has_parent(target_root)\n\n    # Ensure full DAG paths for roots\n    source_root_fp = cmds.ls(source_root, long=True)[0]\n    target_root_fp = cmds.ls(target_root, long=True)[0]\n\n    source_list = [source_root_fp] + get_transform_objects(source_root_fp)\n    target_list = [target_root_fp] + get_transform_objects(target_root_fp)\n\n    match_string_and_keyframes(source_list, target_list, strip_trailing_digits=strip_trailing_digits)\n\n# Example usage:\n# Select source root, then target root, then run:\nrun_transfer(strip_trailing_digits=True)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
