        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef get_skinClusters_for_joint(joint, seen_clusters):\n    outputs = cmds.listConnections(f\"{joint}.worldMatrix[0]\", destination=True, plugs=False) or []\n\n    for node in outputs:\n        if node and cmds.nodeType(node) == 'skinCluster':\n            if node not in seen_clusters:\n                seen_clusters.append(node)    \n\nall_connections = {}\nclusters = []\n\n### get joint heir ###\nselection = cmds.ls(sl=True, type='joint')\nif not selection:\n    raise ValueError(\"Please select a joint.\")\n    \njoint = selection[0]\n\njoints = cmds.listRelatives(joint, ad=True, type='joint') or []\njoints = [joint] + joints\n\nprint(joints)\n\n### save joint connections, and disconnect ###\nprint('disconnecting')\n\nfor jnt in joints:\n    \n    skinClusters = get_skinClusters_for_joint(jnt, clusters)\n    print(clusters)\n    \n    src_attr = f\"{jnt}.worldMatrix[0]\"\n    connections = cmds.listConnections(src_attr, plugs=True, destination=True, source=False) or []\n    print(connections)\n\n    jnt_connections = [(src_attr, con) for con in connections]\n    all_connections[jnt] = jnt_connections\n    for _, con in jnt_connections:\n        try:\n            cmds.disconnectAttr(src_attr,con)\n            print(f\"disconnecting -X- {src_attr} from {con}\")\n        except Exception as e:\n            cmds.warning(f'Failed to disconnect {src_attr} from {con}: {e}')\n\n### freeze transforms per joint ###\nprint('freezing')\n\nfor jnt in joints:\n    #makeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1;\n    cmds.makeIdentity(jnt, a=True, t=True, r=True, s=True, pn=True)\n    \nprint('reconnecting')\n\nfor jnt, connections in all_connections.items():\n    for src, dest in connections:\n        cmds.connectAttr(src, dest, force= True)\n        print(f\"reconnecting --> {src} to {con}\")\n\n###\nfor cluster in clusters:\n    print(cluster)\n    infs = cmds.listConnections(f\"{cluster}.matrix\")\n    for i, inf in enumerate(infs):\n        m = cmds.getAttr( inf + '.worldInverseMatrix' )\n        cmds.setAttr(f'{cluster}.bindPreMatrix[' + str(i) + ']', m[0], m[1], m[2], m[3], m[4], m[5], m[6], m[7], m[8], m[9], m[10], m[11], m[12], m[13], m[14], m[15], typ= 'matrix' )\n        \n\n### Reference - This is the code that resets back to the prebind matrix. ###\n\n'''infs = cmds.listConnections('skinCluster33.matrix')\nprint(infs)\n\nfor i, inf in enumerate( infs ):\n    m = cmds.getAttr( inf + '.worldInverseMatrix' )\n    cmds.setAttr('skinCluster33.bindPreMatrix[' + str(i) + ']', m[0], m[1], m[2], m[3], m[4], m[5], m[6], m[7], m[8], m[9], m[10], m[11], m[12], m[13], m[14], m[15], typ= 'matrix' )\n    \n    \n###\n\n'''\n\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
