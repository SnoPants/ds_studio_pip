        -command "import maya.cmds as cmds\n\ndef select_children_joints():\n    \"\"\"Expands the selection to include all child joints of the selected objects.\"\"\"\n    \n    # Get the current selection\n    selected = cmds.ls(selection=True)\n\n    if not selected:\n        cmds.warning(\"Please select at least one object.\")\n        return\n\n    all_joints = []\n\n    # Iterate through each selected object\n    for obj in selected:\n        # Get all descendant joints\n        child_joints = cmds.listRelatives(obj, allDescendents=True, type=\"joint\", fullPath=True) or []\n        all_joints.extend(child_joints)\n\n    # Add the original selection to the final list\n    all_joints.extend(selected)\n\n    # Remove duplicates and select everything\n    all_joints = list(set(all_joints))\n    cmds.select(all_joints, replace=True)\n\n    print(f\"Selection expanded to {len(all_joints)} joints.\")\n\n# Run the function\nselect_children_joints()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
