        -command "import maya.cmds as cmds\n\n# List all nodes in the scene\nall_nodes = cmds.ls()\n\n# Filter nodes containing 'ngSkinToolsData' in their names\nngskin_nodes = [node for node in all_nodes if 'ngSkinToolsData' in node]\n\n# Delete matching nodes\nif ngskin_nodes:\n    cmds.delete(ngskin_nodes)\n    print(\"Deleted nodes:\", ngskin_nodes)\nelse:\n    print(\"No matching ngSkinToolsData nodes found.\")\n" 
