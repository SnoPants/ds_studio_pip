        -marginHeight 1
        -command "import maya.cmds as cmds\nimport re\nimport difflib\n\ndef get_descendant_geometry(root):\n    \"\"\"Gets all descendant geometry of the given root object or falls back to root if no descendants.\"\"\"\n    descendants = cmds.listRelatives(root, allDescendents=True, shapes=False)\n\n    # Fallback to root if no descendants found\n    if not descendants:\n        descendants = [root]\n\n    filtered_list = [name for name in descendants if 'Shape' not in name and 'Orig' not in name]\n    \n    mesh = []\n    for obj in filtered_list:\n        # Check if it's a mesh transform (has a mesh shape under it) or a mesh shape\n        if cmds.nodeType(obj) == 'mesh':\n            mesh.append(obj)\n        elif cmds.listRelatives(obj, shapes=True, type='mesh'):\n            mesh.append(obj)\n\n    print('got descendants: ', mesh)\n    return mesh\n\n\ndef get_skin_cluster(mesh):\n    \"\"\"Returns the skin cluster connected to the given mesh, or None if not found.\"\"\"\n    history = cmds.listHistory(mesh, pruneDagObjects=True) or []\n    print(f'history of {mesh}: ',history)\n    if history:\n        skin_clusters = [node for node in history if cmds.nodeType(node) == 'skinCluster']\n        if skin_clusters: \n            return mesh, skin_clusters[0]\n        else:\n            cmds.warning(f'No skinCluster in {mesh}')\n            return None\n\ndef get_skinned_descendants(descendants):\n    \"\"\"Gets all skinned descendant geometries of the given root object.\"\"\"\n    \n    print('descendants:', descendants)\n    skinned_meshes = []\n    \n    for mesh in descendants:\n        skin_cluster = get_skin_cluster(mesh)\n        if skin_cluster:\n            skinned_meshes.append((skin_cluster))\n            \n    return skinned_meshes\n            \ndef match_names(name1, name2, threshold=0.95):\n    print('in match names: ', name1, name2)\n    name1_clean = clean(name1)\n    name2_clean = clean(name2)\n    print(name1_clean, name2_clean)\n    \n    similarity = difflib.SequenceMatcher(None, name1_clean, name2_clean).ratio()\n    print('Similarity:', similarity)\n    \n    return similarity >= threshold\n    \ndef clean(name):\n    return re.sub(r'[^a-zA-Z0-9]', '', name.split('|')[-1].lower())\n\ndef skin_selections():\n    selection = cmds.ls(selection=True)\n    print('selected :', selection)\n    if len(selection) != 2:\n        cmds.warning(\"Please select exactly two objects.\")\n        return\n        \n    non_skinned = get_descendant_geometry(selection[0])\n    skinned_meshes = get_descendant_geometry(selection[1])\n    \n    cluster_pairs = []\n    for first in non_skinned:\n        print('non_skinned ',first)\n        for mesh in skinned_meshes:\n            print(mesh)\n            cluster= get_skin_cluster(mesh)[1]\n            print('cluster ', mesh)\n            if match_names(first, mesh):\n                joints = cmds.skinCluster(cluster, query=True,inf=True)  \n                new_skin_cluster = cmds.skinCluster(joints, first, tsb= True)[0]\n                cmds.copySkinWeights(ss= cluster, ds= new_skin_cluster, nm= True, sa= 'closestPoint', ia= 'closestJoint')\n                print(f'Finished creating and copying source skincluster from: {mesh} to: {new_skin_cluster}')\n                cluster_pairs.append(cluster)\n                break\n                \n    for old_cluster in cluster_pairs:\n        cmds.skinCluster(old_cluster, edit=True, unbind=True)\n\n# Run the function\nskin_selections()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
