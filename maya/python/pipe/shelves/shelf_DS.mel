        -annotation "This will reassign materials of selected objects to correct material (WIP - assigns based on suffix of hardcoded number)" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Re_Mat" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Re_Mat" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef select_faces_by_material(material_name):\n    \"\"\"\n    Returns all mesh faces assigned to the given material.\n    \"\"\"\n    if not cmds.objExists(material_name):\n        return []\n\n    faces = []\n    shading_engines = cmds.listConnections(material_name, type=\"shadingEngine\") or []\n    for sg in shading_engines:\n        members = cmds.sets(sg, query=True) or []\n        faces.extend(members)\n\n    return faces\n\n\ndef reassign_material_without_1(materials):\n    \"\"\"\n    If a material ends with '1', reassign all faces using it to the version without '1'.\n    \"\"\"\n\t#TODO: Need to make this more robust, instead of hardcoding '1' do a fnmatch with wild cards.\n    for mat in materials:\n        if mat.endswith(\"2\"):\n            base_mat = mat[:-1]\n\n            if cmds.objExists(base_mat):\n                faces = select_faces_by_material(mat)\n                if faces:\n                    print(f\"Reassigning {len(faces)} faces from '{mat}' to '{base_mat}'\")\n                    cmds.select(faces, replace=True)\n                    cmds.hyperShade(assign=base_mat)\n                    cmds.select(clear=True)\n                else:\n                    print(f\"No faces found using material '{mat}'\")\n            else:\n                print(f\"?? No matching material found for: '{base_mat}'\")\n\n    print(\"? Material reassignment complete.\")\n\n\n# --- Entry Point ---\nmeshes = cmds.ls(selection=True, dag=True, type=\"mesh\", long=True)\nif not meshes:\n    cmds.warning(\"Please select at least one mesh object.\")\nelse:\n    for mesh in meshes:\n        shading_engines = cmds.listConnections(mesh, type=\"shadingEngine\") or []\n        for sg in shading_engines:\n            materials = cmds.ls(cmds.listConnections(f\"{sg}.surfaceShader\"), materials=True) or []\n            reassign_material_without_1(materials)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "First select source object, then your target object and copys name to the target object. (This will delete your first object.)" 
        -enableBackground 0
